# Database (XAMPP / phpMyAdmin lokal)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Default XAMPP: user "root" tanpa password
DATABASE_URL="mysql://root:@localhost:3306/finance_app"

# NextAuth - generate dengan: openssl rand -base64 32
NEXTAUTH_SECRET="ganti-dengan-string-random-panjang-untuk-production"
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="ganti-dengan-string-random-panjang-untuk-production"
AUTH_TRUST_HOST="true"
